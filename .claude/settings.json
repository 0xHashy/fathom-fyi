{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm publish)",
      "Bash(npm view *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git branch *)",
      "Bash(curl -s https://fathom.fyi/*)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env.local)",
      "Bash(rm -rf *)",
      "Bash(cat .env*)",
      "Bash(curl * sk_live*)",
      "Bash(curl * whsec_*)",
      "Bash(echo *KEY*)",
      "Bash(echo *SECRET*)",
      "Bash(echo *PRIVATE*)"
    ]
  }
}
