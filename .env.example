# Required — get free keys at the URLs below
CG_API_KEY=your_coingecko_api_key        # https://www.coingecko.com/en/api
FRED_API_KEY=your_fred_api_key            # https://fred.stlouisfed.org/docs/api/api_key.html

# Fathom API Key — get one at https://fathom.fyi
# Determines your tier. No key = free tier (3 tools, 10 req/hr).
FATHOM_API_KEY=

# Optional
CACHE_ENABLED=true
FATHOM_DATA_DIR=./data
FATHOM_WORKER_INTERVAL_MS=60000
