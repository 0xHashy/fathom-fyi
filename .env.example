# Fathom works out of the box with zero config.
# Free tier: 3 tools, no keys needed.

# Paid tier: one key unlocks everything.
# Subscribe at https://fathom.fyi — key is emailed instantly.
# All data sources are handled server-side. No other keys needed.
FATHOM_API_KEY=

# Advanced: force direct API calls instead of Fathom's data proxy.
# Only needed if you prefer using your own data source keys.
# FATHOM_DIRECT=true
# CG_API_KEY=
# FRED_API_KEY=
